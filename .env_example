# Primary provider/model
PRIMARY_PROVIDER=qwen
PRIMARY_MODEL=qwen-plus

# Optional backward-compatible aliases
PROVIDER=qwen
MODEL=qwen-plus

# Optional content-policy fallback
FALLBACK_ON_CONTENT_POLICY=true
FALLBACK_PROVIDER=openrouter
FALLBACK_MODEL=x-ai/grok-4.1-fast

# Optional Russian glossary override
RUSSIAN_GLOSSARY_PROVIDER=openrouter
RUSSIAN_GLOSSARY_MODEL=mistralai/mistral-small-3.1-24b-instruct

# Optional Japanese glossary override
JAPANESE_GLOSSARY_PROVIDER=openrouter
JAPANESE_GLOSSARY_MODEL=anthropic/claude-sonnet-4.5

# Provider API keys
GEMINI_API_KEY=xxx
QWEN_API_KEY=xxx
MIMO_API_KEY=xxx
OPENROUTER_API_KEY=xxx

# Optional provider-specific models
# GEMINI_MODEL=gemini-2.5-pro
# QWEN_MODEL=qwen-plus
# MIMO_MODEL=mimo-v2-pro
# OPENROUTER_MODEL=x-ai/grok-4.1-fast

# Optional provider-specific base URLs
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter request tuning
# OPENROUTER_REASONING_ENABLED=true
